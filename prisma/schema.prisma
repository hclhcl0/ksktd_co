datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Account {
  id          String   @id @default(cuid())
  username    String   @unique
  displayName String
  password    String
  role        String   // 'admin' or 'unit'
  status      String   @default("approved") // 'pending', 'approved', 'rejected'
  orgType     String   @default("") // 'school', 'military', 'enterprise', 'other', or empty for defaults
  allowEditOverride Boolean @default(false)
  facilityName String? 
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model HealthReport {
  id                 String   @id @default(cuid())
  don_vi             String
  ngay_kham          String
  co_so_y_te         String
  nguoi_nop_bao_cao  String
  
  nguoi_cao_tuoi     Int      @default(0)
  nguoi_khuyet_tat   Int      @default(0)
  ho_ngheo           Int      @default(0)
  ho_can_ngheo       Int      @default(0)
  nguoi_co_cong      Int      @default(0)
  vung_kho_khan      Int      @default(0)
  tre_em_duoi_6_tuoi Int      @default(0)
  hoc_sinh_sinh_vien Int      @default(0)
  luc_luong_vu_trang Int      @default(0)
  nguoi_lao_dong     Int      @default(0)
  
  created_at         DateTime @default(now())

  details            HealthReportData[]

  @@index([don_vi])
  @@index([created_at])
}

model Benchmark {
  id                 String   @id @default(cuid())
  don_vi             String   @unique
  nguoi_cao_tuoi     Int?
  nguoi_khuyet_tat   Int?
  ho_ngheo           Int?
  ho_can_ngheo       Int?
  nguoi_co_cong      Int?
  vung_kho_khan      Int?
  tre_em_duoi_6_tuoi Int?
  hoc_sinh_sinh_vien Int?
  luc_luong_vu_trang Int?
  nguoi_lao_dong     Int?
  updatedAt          DateTime @updatedAt

  details            BenchmarkData[]
}

model Vaccine {
  id          String   @id @default(cuid())
  name        String
  description String?
  
  campaigns   CampaignVaccine[]
  reports     VaccinationReport[]
}

model VaccineCampaign {
  id          String   @id @default(cuid())
  name        String
  startDate   String
  endDate     String
  status      String   // 'active' or 'completed'
  
  vaccines    CampaignVaccine[]
  reports     VaccinationReport[]
}

model CampaignVaccine {
  id             String          @id @default(cuid())
  campaignId     String
  vaccineId      String
  totalAllocated Int
  
  campaign       VaccineCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  vaccine        Vaccine         @relation(fields: [vaccineId], references: [id], onDelete: Cascade)

  @@unique([campaignId, vaccineId])
}

model VaccinationReport {
  id                 String   @id @default(cuid())
  campaignId         String
  vaccineId          String
  don_vi             String
  ngay_tiem          String
  nguoi_nop_bao_cao  String
  
  nguoi_cao_tuoi     Int      @default(0)
  nguoi_khuyet_tat   Int      @default(0)
  ho_ngheo           Int      @default(0)
  ho_can_ngheo       Int      @default(0)
  nguoi_co_cong      Int      @default(0)
  vung_kho_khan      Int      @default(0)
  tre_em_duoi_6_tuoi Int      @default(0)
  hoc_sinh_sinh_vien Int      @default(0)
  luc_luong_vu_trang Int      @default(0)
  nguoi_lao_dong     Int      @default(0)
  
  created_at         DateTime @default(now())

  campaign           VaccineCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  vaccine            Vaccine         @relation(fields: [vaccineId], references: [id], onDelete: Cascade)
  details            VaccinationReportData[]

  @@index([don_vi])
  @@index([campaignId])
  @@index([vaccineId])
  @@index([created_at])
}

model DemographicGroup {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  shortLabel  String
  icon        String?
  color       String?
  isActive    Boolean  @default(true)
  isGlobal    Boolean  @default(true)
  appliedUnits String[] @default([])
  createdAt   DateTime @default(now())

  healthData  HealthReportData[]
  benchmarks  BenchmarkData[]
  vacData     VaccinationReportData[]
}

model HealthReportData {
  id          String   @id @default(cuid())
  reportId    String
  groupKey    String
  count       Int      @default(0)

  report      HealthReport     @relation(fields: [reportId], references: [id], onDelete: Cascade)
  group       DemographicGroup @relation(fields: [groupKey], references: [key], onDelete: Cascade)

  @@unique([reportId, groupKey])
  @@index([reportId])
}

model BenchmarkData {
  id          String   @id @default(cuid())
  don_vi      String
  groupKey    String
  target      Int?

  benchmark   Benchmark        @relation(fields: [don_vi], references: [don_vi], onDelete: Cascade)
  group       DemographicGroup @relation(fields: [groupKey], references: [key], onDelete: Cascade)

  @@unique([don_vi, groupKey])
}

model VaccinationReportData {
  id          String   @id @default(cuid())
  reportId    String
  groupKey    String
  count       Int      @default(0)

  report      VaccinationReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  group       DemographicGroup  @relation(fields: [groupKey], references: [key], onDelete: Cascade)

  @@unique([reportId, groupKey])
  @@index([reportId])
}

model SystemSetting {
  key       String   @id // e.g., 'allow_unit_report_edit'
  value     String   // e.g., 'true', 'false'
  updatedAt DateTime @updatedAt
}

model Facility {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ActivityLog {
  id          String   @id @default(cuid())
  unitName    String   // Đơn vị thực hiện
  username    String   // Tài khoản thực hiện
  action      String   // CREATE, UPDATE, DELETE
  entityType  String   // health_report, vaccination_report, settings, benchmark, demographic_group...
  entityId    String?  // ID của bản ghi bị tác động (nếu có)
  details     String?  @db.Text // Mô tả chi tiết (ví dụ chuỗi JSON cũ/mới hoặc thông báo text)
  createdAt   DateTime @default(now())

  @@index([unitName])
  @@index([action])
  @@index([entityType])
  @@index([createdAt])
}
